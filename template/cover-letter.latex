% Pandoc LaTeX template for cover letters — ATS-safe, resume-coherent layout.
% Variables: name, email, phone, location, linkedin (optional), letter_date
% Body: salutation through sign-off from cover-letter-<voice>.md

\documentclass[11pt,a4paper]{article}

\usepackage[margin=1in]{geometry}
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage[default]{lato}
\usepackage{xcolor}
\usepackage{parskip}
\usepackage{ragged2e}
\usepackage{hyperref}
\hypersetup{hidelinks}

\definecolor{IFBlue}{HTML}{0F6688}

\pagestyle{empty}
\raggedright
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.75\baselineskip}

\begin{document}

{\fontsize{15}{18}\selectfont\textbf{\color{IFBlue}$if(name)$$name$$endif$}\par}
\smallskip
{\fontsize{10}{12}\selectfont
$if(email)$Email: $email$$endif$
$if(phone)$ \textbar{} Phone: $phone$$endif$
$if(location)$ \textbar{} Location: $location$$endif$\par
$if(linkedin)$LinkedIn: $linkedin$\par$endif$
}

\medskip
$if(letter_date)$$letter_date$$endif$
\medskip

$body$

\end{document}
